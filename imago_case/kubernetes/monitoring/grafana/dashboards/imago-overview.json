{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "IMAGO Platform Overview — request rates, error rates, latency per service",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto" },
      "title": "Web App — Up",
      "type": "stat",
      "targets": [
        {
          "expr": "count(up{namespace='imago-web', job='web-app'} == 1)",
          "legendFormat": "pods up"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Request Rate by Service",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace='imago-web'}[2m]))",
          "legendFormat": "Web App"
        },
        {
          "expr": "sum(rate(http_requests_total{namespace='imago-search'}[2m]))",
          "legendFormat": "Media Search"
        },
        {
          "expr": "sum(rate(http_requests_total{namespace='imago-download'}[2m]))",
          "legendFormat": "Media Download"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 3,
      "title": "Error Rate by Service (5xx)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace='imago-web',status=~'5..'}[5m])) / sum(rate(http_requests_total{namespace='imago-web'}[5m]))",
          "legendFormat": "Web App"
        },
        {
          "expr": "sum(rate(http_requests_total{namespace='imago-download',status=~'5..'}[5m])) / sum(rate(http_requests_total{namespace='imago-download'}[5m]))",
          "legendFormat": "Media Download"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 4,
      "title": "p99 Latency by Service",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace='imago-web'}[5m])) by (le))",
          "legendFormat": "Web App p99"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace='imago-download'}[5m])) by (le))",
          "legendFormat": "Download p99"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "id": 5,
      "title": "ElasticSearch Cluster Health",
      "type": "stat",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "elasticsearch_cluster_health_status{color='green'} * 2 + elasticsearch_cluster_health_status{color='yellow'} * 1",
          "legendFormat": "Health"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["imago", "platform", "overview"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "IMAGO Platform Overview",
  "uid": "imago-platform-overview",
  "version": 1
}
